<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".ClassificationActivity">

    <EditText
        android:id="@+id/etClassificationScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/et_nilai_hint"
        android:inputType="number" />

    <Button
        android:id="@+id/btnClassificationShow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/design_default_color_primary"
        android:text="@string/classification_title"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/tvClassificationResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/hasilnya"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:textSize="35sp" />


</LinearLayout>